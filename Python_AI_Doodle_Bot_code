#include <Stepper.h>
#include <ESP32Servo.h>

#define STEPS 200

Stepper motor1(STEPS, 14, 27, 26, 25);
Stepper motor2(STEPS, 33, 32, 18, 19);

Servo penServo;
int servoPin = 13;

int lightPin = 23;
int robotSpeed = 150;

void moveForward(int steps){
  motor1.setSpeed(robotSpeed);
  motor2.setSpeed(robotSpeed);
  for(int i=0;i<steps;i++){
    motor1.step(1);
    motor2.step(1);
  }
}

void rotateAngle(int steps){
  motor1.setSpeed(robotSpeed);
  motor2.setSpeed(robotSpeed);
  for(int i=0;i<steps;i++){
    motor1.step(1);
    motor2.step(-1);
  }
}

void drawCircle(){
  penServo.write(90);
  delay(400);
  motor1.setSpeed(robotSpeed+30);
  motor2.setSpeed(robotSpeed-30);
  for(int i=0;i<3200;i++){
    motor1.step(1);
    motor2.step(1);
  }
  penServo.write(40);
}

void drawSquare(){
  penServo.write(90);
  delay(400);
  for(int i=0;i<4;i++){
    moveForward(1200);
    rotateAngle(600);
  }
  penServo.write(40);
}

void drawTriangle(){
  penServo.write(90);
  delay(400);
  for(int i=0;i<3;i++){
    moveForward(1200);
    rotateAngle(800);
  }
  penServo.write(40);
}

void setup(){
  Serial.begin(115200);
  pinMode(lightPin,OUTPUT);
  penServo.attach(servoPin);

  Serial.println("READY");
}

void loop(){

  if(Serial.available()){

    char cmd = Serial.read();

    if(cmd=='c'){
      Serial.println("Circle");
      drawCircle();
    }

    else if(cmd=='s'){
      Serial.println("Square");
      drawSquare();
    }

    else if(cmd=='t'){
      Serial.println("Triangle");
      drawTriangle();
    }

  }

}




